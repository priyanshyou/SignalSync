# .env.example
# This file serves as a template for project configuration as required by the assignment guidelines.
# To enforce strict behavior over the pipeline, copy this file to `.env` and configure accordingly.

# The depth of the scraping run (controls how many paginated pages are scraped per execution)
SCRAPE_PAGES=3

# The interval in which the background `apscheduler` will run (in hours)
SCHEDULER_INTERVAL_HOURS=1

# Advanced AI Overrides
# By default, the AI Layer uses an in-memory python-native TF-IDF approach for instant portability.
# If you wish to swap this locally to a remote LLM API, insert your token here:
# OPENAI_API_KEY=sk-...
